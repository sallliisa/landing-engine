@startuml MenuItem Management Sequence Diagram

!define BLUE_COLOR #4A90E2
!define GREEN_COLOR #7ED321
!define RED_COLOR #D0021B
!define ORANGE_COLOR #F5A623
!define PURPLE_COLOR #9013FE

actor "User" as User BLUE_COLOR
participant "Frontend\nApplication" as Frontend ORANGE_COLOR
participant "API Engine\n(/api/[model])" as APIEngine PURPLE_COLOR
participant "MenuItem\nConfig" as Config GREEN_COLOR
participant "Database\n(PostgreSQL)" as Database GREEN_COLOR

== Create MenuItem ==
box "Create Operation" #LightBlue
    User -> Frontend: Initiate create menu item
    Frontend -> APIEngine: POST /api/menuItem/create\n{ menuItemData }
    activate APIEngine

    APIEngine -> Config: Load MenuItem configuration
    Config -> Config: Validate required fields\n(name validation)
    Config -> Config: Execute pre-lifecycle hooks\n- Set level based on parent\n- Calculate order\n- Generate slug\n- Set visibility
    Config -> Database: Create menu item record
    activate Database
    Database --> Config: MenuItem created
    deactivate Database
    Config -> Config: Execute post-lifecycle hooks\n- Create translations for all languages
    Config -> Database: Create translation records
    activate Database
    Database --> Config: Translations created
    deactivate Database

    APIEngine --> Frontend: Return created menu item
    deactivate APIEngine
    Frontend --> User: Display success message
end box

== Update MenuItem ==
box "Update Operation" #LightGreen
    User -> Frontend: Select menu item to edit
    Frontend -> APIEngine: PUT /api/menuItem/update/{id}\n{ updatedData }
    activate APIEngine

    APIEngine -> Config: Load MenuItem configuration
    Config -> Config: Validate update fields\n(order validation)
    Config -> Config: Execute pre-lifecycle hooks\n- Handle role conflicts\n- Set default visibility
    Config -> Database: Update menu item record
    activate Database
    Database --> Config: MenuItem updated
    deactivate Database
    Config -> Config: Execute post-lifecycle hooks\n- Handle primary role visibility
    Config -> Database: Update related records if needed
    activate Database
    Database --> Config: Related records updated
    deactivate Database

    APIEngine --> Frontend: Return updated menu item
    deactivate APIEngine
    Frontend --> User: Display updated menu item
end box

== Delete MenuItem ==
box "Delete Operation" #LightRed
    User -> Frontend: Select menu item to delete
    Frontend -> APIEngine: DELETE /api/menuItem/delete/{id}
    activate APIEngine

    APIEngine -> Config: Load MenuItem configuration
    Config -> Config: Validate delete operation
    Config -> Database: Delete menu item record
    activate Database
    Database --> Config: MenuItem deleted
    deactivate Database
    Config -> Database: Delete related records\n(translations, children)
    activate Database
    Database --> Config: Related records deleted
    deactivate Database

    APIEngine --> Frontend: Return deletion confirmation
    deactivate APIEngine
    Frontend --> User: Display deletion success
end box

== List MenuItems ==
box "List Operation" #LightYellow
    User -> Frontend: Request menu items list
    Frontend -> APIEngine: GET /api/menuItem/list\n?filters&search&pagination
    activate APIEngine

    APIEngine -> Config: Load MenuItem configuration
    Config -> Config: Apply list configurations\n- Searchable fields (id)\n- Filterable fields (parent_id, level)\n- Order by (order: asc)\n- Include foreign fields (translations, page, allowedRoles)
    Config -> Database: Query menu items with filters
    activate Database
    Database --> Config: MenuItem records with relations
    deactivate Database
    Config -> Config: Execute post-lifecycle hooks\n- Add can_edit permissions\n- Process page translations\n- Apply role-based access
    Config -> Config: Format response data

    APIEngine --> Frontend: Return filtered menu items list
    deactivate APIEngine
    Frontend -> Frontend: Process and display menu items
    Frontend --> User: Display menu items with permissions
end box

== Error Handling ==
alt Any Operation Fails
    APIEngine -> Frontend: Return error response\n(400, 403, 404, 500)
    Frontend -> Frontend: Handle error state
    Frontend --> User: Display error message
end alt

== Notes ==
note over Frontend, Database
    **MenuItem Features:**
    - Hierarchical structure (parent/children)
    - Multi-language support (translations)
    - Role-based permissions (allowedRoles)
    - Page associations
    - Visibility and ordering controls
    - Automatic slug generation
    - Level-based organization

    **API Engine Pattern:**
    - Generic CRUD operations
    - Configuration-driven behavior
    - Lifecycle hooks for custom logic
    - Validation and file processing
    - Permission-based access control
end note

@enduml
