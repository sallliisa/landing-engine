@startuml Content Update Sequence Diagram

!define BLUE_COLOR #4A90E2
!define GREEN_COLOR #7ED321
!define ORANGE_COLOR #F5A623
!define PURPLE_COLOR #9013FE

actor "User" as User BLUE_COLOR
participant "Frontend\nApplication" as Frontend ORANGE_COLOR
participant "API Engine\n(/api/[model])" as APIEngine PURPLE_COLOR
participant "Content\nConfig" as Config GREEN_COLOR
participant "Database\n(PostgreSQL)" as Database GREEN_COLOR
participant "Draft State\nManager" as DraftManager ORANGE_COLOR

== Content Update Operation ==
box "Update Content" #LightGreen
    User -> Frontend: Edit content properties\n(media, title, description, etc.)
    Frontend -> APIEngine: PUT /api/content/update/{id}\n{ updatedContentFields }
    activate APIEngine

    APIEngine -> Config: Load Content configuration
    Config -> Config: Validate allowed update fields\n- media, title, subtitle, description\n- label, content, blurb, media_type\n- attachment, status, order, url\n- url_text, url_type, amount, collection, meta
    Config -> DraftManager: Execute pre-lifecycle hook\n- Extract page_translation_id from body\n- Call ensureDraftState() for draft management
    activate DraftManager
    DraftManager -> DraftManager: Check if content needs draft state handling
    DraftManager -> DraftManager: Handle ID mapping for draft versions
    DraftManager --> Config: Return processed body with draft state
    deactivate DraftManager

    alt Draft ID Mapping Required
        Config -> Config: Map old content ID to new draft ID
        Config -> Config: Update body with new content ID
    end alt

    Config -> Database: Update content record with new values
    activate Database
    Database --> Config: Content updated successfully
    deactivate Database

    APIEngine --> Frontend: Return updated content data
    deactivate APIEngine
    Frontend -> Frontend: Refresh content display
    Frontend --> User: Show updated content
end box

== Error Handling ==
alt Update Fails
    APIEngine -> Frontend: Return error response\n(400, 403, 404, 500)
    Frontend -> Frontend: Handle error state
    Frontend --> User: Display error message
end alt

== Notes ==
note over Frontend, Database
    **Content Update Features:**
    - Comprehensive field updates (media, text, metadata)
    - Draft state integration for content versioning
    - Automatic ID mapping for draft content
    - Gallery association maintained during updates

    **Allowed Update Fields:**
    - media: File uploads and media content
    - title, subtitle, description: Text content
    - label, content, blurb: Display text
    - media_type: Content type classification
    - attachment: File attachments
    - status: Content publication status
    - order: Display ordering within galleries
    - url, url_text, url_type: Link configuration
    - amount, collection: Specialized content fields
    - meta: Additional metadata storage

    **Draft State Management:**
    - Automatic draft creation/validation
    - ID mapping between draft and published versions
    - Prevents conflicts during content editing
    - Maintains content integrity across versions
end note

@enduml
